# Copy this file to .env.mcp and fill in secrets.
# Keep .env.mcp out of version control.

# Existing llmLibrarian runtime config
LLMLIBRARIAN_DB=/Users/tjm4/llmLibrarian/my_brain_db
LLMLIBRARIAN_MODEL=llama3.1:8b
LLMLIBRARIAN_CHUNK_SIZE=1000
LLMLIBRARIAN_CHUNK_OVERLAP=150
LLMLIBRARIAN_RERANK=0

# Linux only: cap glibc malloc arenas and lower the trim threshold so a
# long-lived MCP+torch process doesn't retain freed heap indefinitely (default
# is 8*ncpu arenas, which can bloat anon RSS into the tens of GB over hours of
# ingest churn). Safe to leave set on macOS — the runtime ignores them.
MALLOC_ARENA_MAX=2
MALLOC_TRIM_THRESHOLD_=131072

# Optional: Chroma server mode (safe MCP + pal pull concurrently)
# LLMLIBRARIAN_CHROMA_HOST=127.0.0.1
# LLMLIBRARIAN_CHROMA_PORT=8000

# MCP network serving config
LLMLIBRARIAN_MCP_TRANSPORT=streamable-http
LLMLIBRARIAN_MCP_HOST=127.0.0.1
LLMLIBRARIAN_MCP_PORT=8765
LLMLIBRARIAN_MCP_PATH=/mcp
LLMLIBRARIAN_MCP_STATELESS_HTTP=true
LLMLIBRARIAN_MCP_LOG_LEVEL=warning
LLMLIBRARIAN_MCP_REQUIRE_AUTH=false

# Optional: set to true to require static Bearer auth.
# Example generation:
#   openssl rand -hex 32
LLMLIBRARIAN_MCP_AUTH_TOKEN=replace_me_if_auth_enabled
