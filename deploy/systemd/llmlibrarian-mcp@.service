[Unit]
Description=llmLibrarian MCP HTTP service
After=network.target

[Service]
Type=simple
WorkingDirectory={{INSTALL_DIR}}
ExecStart={{INSTALL_DIR}}/scripts/run_mcp_http.sh
Restart=on-failure
RestartSec=5
CPUQuota=80%
MemoryMax=4G
Nice=5
# Default soft limit is 1024; chromadb HTTP client + watcher retries can blow
# through that during a re-index storm. Raise so transient socket/fd churn
# doesn't cascade into EMFILE -> empty-registry reads -> false "silo not found".
LimitNOFILE=65536
Environment=LLMLI_MCP_ENV_FILE={{INSTALL_DIR}}/.env.mcp

[Install]
WantedBy=default.target
